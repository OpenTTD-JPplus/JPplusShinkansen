
/* cab001 */
// Sprites
	// E2 200
	spriteset(ss_std_e2_series_200_cab001_irl, ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP, "src/trains/e2_series/gfx/e2_200.png") {tmpl_10(1)}
	spriteset(ss_frt_e2_series_200_cab001_irl, ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP, "src/trains/e2_series/gfx/e2_200.png") {tmpl_frt(1)}
	spriteset(ss_mid_e2_series_200_cab001_irl, ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP, "src/trains/e2_series/gfx/e2_200.png") {tmpl_mid(1)}
	spriteset(ss_bck_e2_series_200_cab001_irl, ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP, "src/trains/e2_series/gfx/e2_200.png") {tmpl_bck(1)}

	// E2 200 2cc
	spriteset(ss_std_e2_series_200_cab001_2cc, "src/trains/e2_series/gfx/e2_200_2cc.png") {tmpl_10(1)}
	spriteset(ss_frt_e2_series_200_cab001_2cc, "src/trains/e2_series/gfx/e2_200_2cc.png") {tmpl_frt(1)}
	spriteset(ss_mid_e2_series_200_cab001_2cc, "src/trains/e2_series/gfx/e2_200_2cc.png") {tmpl_mid(1)}
	spriteset(ss_bck_e2_series_200_cab001_2cc, "src/trains/e2_series/gfx/e2_200_2cc.png") {tmpl_bck(1)}

	// Lights
	spriteset(sw_std_e2_series_200_cab001_lights_fwd, ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP, "src/trains/e2_series/gfx/e2_lights_fwd.png") {tmpl_10(1)}
	spriteset(sw_mid_e2_series_200_cab001_lights_fwd, ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP, "src/trains/e2_series/gfx/e2_lights_fwd.png") {tmpl_mid(1)}
	spriteset(sw_std_e2_series_200_cab001_lights_bck, ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP, "src/trains/e2_series/gfx/e2_lights_bck.png") {tmpl_10(1)}
	spriteset(sw_mid_e2_series_200_cab001_lights_bck, ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP, "src/trains/e2_series/gfx/e2_lights_bck.png") {tmpl_mid(1)}

// Sprite Selection

	// Front
	switch(FEAT_TRAINS, PARENT, ss_frt_e2_series_200_cab001_mask, cargo_subtype) {1:ss_frt_e2_series_200_cab001_2cc;}

	switch(FEAT_TRAINS, SELF, sw_e2_series_200_cab001_frt_stack, [
		STORE_TEMP(CB_FLAG_MORE_SPRITES | PALETTE_USE_DEFAULT, 0x100), getbits(extra_callback_info1, 8, 8) ]) {
			0: ss_frt_e2_series_200_cab001_irl;
			1: ss_frt_e2_series_200_cab001_mask;
		}

	switch(FEAT_TRAINS, SELF, sw_e2_series_200_cab001_frt_longsprite, NextPartSame() ) { 1: sw_e2_series_200_cab001_frt_stack; dummy_sprites; }

	/* MID */

	// Mid Parts
		switch(FEAT_TRAINS, PARENT, sw_mid_e2_series_200_cab001_mask, cargo_subtype) {1:ss_mid_e2_series_200_cab001_2cc;}

	// Mid LongSprite
		// Base
			switch(FEAT_TRAINS, SELF, sw_std_e2_series_200_cab001_base, HideLongSprite() ) { 0: ss_std_e2_series_200_cab001_irl; }
		// Masks
			switch(FEAT_TRAINS, PARENT, sw_std_e2_series_200_cab001_mask_subtypes, cargo_subtype) {1:ss_std_e2_series_200_cab001_2cc;}
			switch(FEAT_TRAINS, SELF, sw_std_e2_series_200_cab001_mask, HideLongSprite() ) { 0: sw_std_e2_series_200_cab001_mask_subtypes; }

	// Lights
		switch (FEAT_TRAINS, PARENT, sw_e2_series_200_cab001_lights_longsprite, vehicle_is_reversed) { 1: sw_std_e2_series_200_cab001_lights_bck; sw_std_e2_series_200_cab001_lights_fwd;}
		switch (FEAT_TRAINS, PARENT, sw_mid_e2_series_200_cab001_lights, vehicle_is_reversed) { 1: sw_mid_e2_series_200_cab001_lights_bck; sw_mid_e2_series_200_cab001_lights_fwd;}
		switch(FEAT_TRAINS, SELF, sw_std_e2_series_200_cab001_lights, HideLongSprite() ) { 0: sw_e2_series_200_cab001_lights_longsprite; }

	switch(FEAT_TRAINS, SELF, sw_e2_series_200_cab001_mid_stack, [
		STORE_TEMP(CB_FLAG_MORE_SPRITES | PALETTE_USE_DEFAULT, 0x100), getbits(extra_callback_info1, 8, 8) ]) {
			0: ss_mid_e2_series_200_cab001_irl;
			1: sw_mid_e2_series_200_cab001_mask;
			2: sw_mid_e2_series_200_cab001_lights;
			3: sw_std_e2_series_200_cab001_base;
			4: sw_std_e2_series_200_cab001_mask;
			5: sw_std_e2_series_200_cab001_lights;
		}

	// Back
	switch(FEAT_TRAINS, PARENT, ss_bck_e2_series_200_cab001_mask, cargo_subtype) {1:ss_bck_e2_series_200_cab001_2cc;}

	switch(FEAT_TRAINS, SELF, sw_e2_series_200_cab001_bck_stack, [
		STORE_TEMP(CB_FLAG_MORE_SPRITES | PALETTE_USE_DEFAULT, 0x100), getbits(extra_callback_info1, 8, 8) ]) {
			0: ss_bck_e2_series_200_cab001_irl;
			1: ss_bck_e2_series_200_cab001_mask;
		}

	switch(FEAT_TRAINS, SELF, sw_e2_series_200_cab001_bck_longsprite, PrevPartSame() ) { 1: sw_e2_series_200_cab001_bck_stack; dummy_sprites; }

	switch (FEAT_TRAINS, SELF, sw_e2_series_200_cab001, position_in_consist % 3 ) {				
		0: sw_e2_series_200_cab001_frt_longsprite;
		1: sw_e2_series_200_cab001_mid_stack;
		2: sw_e2_series_200_cab001_bck_longsprite;
	}


/* cab002 */
