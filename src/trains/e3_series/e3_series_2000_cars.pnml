
/* cab001 */

	spriteset(sw_mid_e3_series_2000_cab001_irl, ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP, "src/trains/e3_series/gfx/e3_2000.png") {tmpl_mid(1)}
	spriteset(sw_mid_e3_series_2000_cab001_2cc, "src/trains/e3_series/gfx/e3_2000_2cc.png") {tmpl_mid(1)}

	spriteset(sw_mid_e3_series_2000_cab001_lights_fwd, ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP, "src/trains/e3_series/gfx/e3_lights_fwd.png") {tmpl_mid(1)}
	spriteset(sw_mid_e3_series_2000_cab001_lights_bck, ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP, "src/trains/e3_series/gfx/e3_lights_bck.png") {tmpl_mid(1)}

	switch (FEAT_TRAINS, PARENT, sw_mid_e3_series_2000_cab001_lights, vehicle_is_reversed) { 1: sw_mid_e3_series_2000_cab001_lights_bck; sw_mid_e3_series_2000_cab001_lights_fwd;}

	switch(FEAT_TRAINS, PARENT, sw_mid_e3_series_2000_cab001_base, cargo_subtype) {0:sw_mid_e3_series_2000_cab001_irl; 1:sw_mid_e3_series_2000_cab001_irl;}
	switch(FEAT_TRAINS, PARENT, sw_mid_e3_series_2000_cab001_mask, cargo_subtype) {1:sw_mid_e3_series_2000_cab001_2cc;}

	switch(FEAT_TRAINS, SELF, sw_e3_series_2000_cab001, [
		STORE_TEMP(CB_FLAG_MORE_SPRITES | PALETTE_USE_DEFAULT, 0x100), getbits(extra_callback_info1, 8, 8) ]) {
			0: sw_mid_e3_series_2000_cab001_base;
			1: sw_mid_e3_series_2000_cab001_mask;
			2: sw_mid_e3_series_2000_cab001_lights;
		}


