			0: ss_bck_e4e3_series_cab002_base;
		}

	switch(FEAT_TRAINS, SELF, sw_e4e3_series_cab002_bck_longsprite, PrevPartSame() ) { 1: sw_e4e3_series_cab002_bck_stack; dummy_sprites; }

	switch (FEAT_TRAINS, SELF, sw_e4e3_series_cab002, position_in_consist % 3 ) {				
