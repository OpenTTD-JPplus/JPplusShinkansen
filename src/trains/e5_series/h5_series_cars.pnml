	switch(FEAT_TRAINS, SELF, sw_h5_series_panto1_mid_stack, [
		STORE_TEMP(CB_FLAG_MORE_SPRITES | PALETTE_USE_DEFAULT, 0x100), getbits(extra_callback_info1, 8, 8) ]) {
			0: sw_mid_h5_series_panto1_base;
			1: sw_mid_h5_series_panto1_mask;
			2: sw_std_h5_series_panto1_base;
			3: sw_std_h5_series_panto1_mask;
		}

	// Back
	switch(FEAT_TRAINS, PARENT, ss_bck_h5_series_panto1_base, cargo_subtype) {0:ss_bck_h5_series_panto1_h5s; 1:ss_bck_h5_series_panto1_h5s;}
	switch(FEAT_TRAINS, PARENT, ss_bck_h5_series_panto1_mask, cargo_subtype) {1:ss_bck_h5_series_panto1_2cc;}

	switch(FEAT_TRAINS, SELF, sw_h5_series_panto1_bck_stack, [
		STORE_TEMP(CB_FLAG_MORE_SPRITES | PALETTE_USE_DEFAULT, 0x100), getbits(extra_callback_info1, 8, 8) ]) {
			0: ss_bck_h5_series_panto1_base;
			1: ss_bck_h5_series_panto1_mask;
		}

	switch(FEAT_TRAINS, SELF, sw_h5_series_panto1_bck_longsprite, PrevPartSame() ) { 1: sw_h5_series_panto1_bck_stack; dummy_sprites; }

	switch (FEAT_TRAINS, SELF, sw_h5_series_panto1, position_in_consist % 3 ) {				
		0: sw_h5_series_panto1_frt_longsprite;
		1: sw_h5_series_panto1_mid_stack;
		2: sw_h5_series_panto1_bck_longsprite;
	}
